generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                Int        @id @default(autoincrement())
  age               Int
  points            Int        @default(0)
  completedMissions Int        @default(0)
  interests         Json?      @default("[]")
  engagementScore   Float      @default(0.5)
  lastSafeMissionAt DateTime?
  safePointsToday   Int        @default(0)
  lastSafeResetDate DateTime?
  createdAt         DateTime   @default(now())
  analyses          Analysis[]
  missions          Mission[]
  missionResults    MissionResult[]
  userBadges        UserBadge[]
}

model Analysis {
  id               Int      @id @default(autoincrement())
  userId           Int
  text             String
  displayText      String?
  matchedKeywords  Json?
  riskScore        Float
  category         String
  usedAI           Boolean  @default(false)
  createdAt        DateTime @default(now())
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Mission {
  id             Int             @id @default(autoincrement())
  userId         Int
  mission        String
  points         Int
  status         String          @default("pending")
  type           String          @default("real_world")
  content        Json?
  difficulty     Int             @default(1)
  createdAt      DateTime        @default(now())
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  missionResults MissionResult[]
}

model MissionResult {
  id           Int      @id @default(autoincrement())
  missionId    Int
  userId       Int
  score        Int?
  success      Boolean
  timeSpent    Int?
  bonusPoints  Int      @default(0)
  earnedPoints Int      @default(0)
  createdAt    DateTime @default(now())
  mission      Mission  @relation(fields: [missionId], references: [id], onDelete: Cascade)
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Badge {
  id               Int        @id @default(autoincrement())
  name             String     @unique
  description      String
  type             String
  requirementValue String
  createdAt        DateTime   @default(now())
  userBadges       UserBadge[]
}

model UserBadge {
  id        Int      @id @default(autoincrement())
  userId    Int
  badgeId   Int
  awardedAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge     Badge    @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeId])
}
