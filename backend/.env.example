PORT=3000
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"

# Full URL to the Python AI /analyze endpoint
AI_ANALYZE_URL=http://127.0.0.1:8000/analyze
# Request timeout in ms (OCR + ML on CPU often needs 30–90s; use 120000+)
AI_REQUEST_TIMEOUT_MS=120000

# Safe mission points controls
SAFE_POINTS_COOLDOWN_MINUTES=5
SAFE_POINTS_DAILY_CAP=10

# Optional: align with ai-service (defaults: 0.4 / 0.85)
# MODERATION_RISKY_THRESHOLD=0.4
# MODERATION_DANGEROUS_THRESHOLD=0.85
